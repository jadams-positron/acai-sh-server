# .env.example — copy to `.env` (gitignored) for local development.
# Used by `just run` which sources this file before invoking ./acai.

# --- App ---
LOG_LEVEL=debug
DATABASE_PATH=./acai.dev.db
HTTP_PORT=4321

# --- Auth / cookies ---
# Generate with: openssl rand -hex 32
SECRET_KEY_BASE=replace_me_with_a_64_char_hex_string_aaaaaaaaaaaaaaaaaaaaaaaa

# --- URL building (used in magic-link emails) ---
URL_HOST=localhost
URL_SCHEME=http
URL_PORT=4321

# --- Mail ---
# MAIL_NOOP=true logs the magic-link URL to slog instead of sending real email.
MAIL_NOOP=true
MAIL_FROM_NAME="Acai (dev)"
MAIL_FROM_EMAIL=noreply@example.com

# When MAIL_NOOP=false, set these too:
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_BASE_URL=https://api.mailgun.net/v3

# --- Google SSO (optional) ---
# When CLIENT_ID and CLIENT_SECRET are set, the login page shows a
# "Sign in with Google" button alongside the magic-link form. Leave
# unset to disable Google auth (magic-link continues to work).
#
# Set up at https://console.cloud.google.com → APIs & Services →
# Credentials → Create OAuth client ID (Web application). Authorized
# redirect URI must be <URL_SCHEME>://<URL_HOST>:<URL_PORT>/auth/google/callback
# (or whatever GOOGLE_AUTH_REDIRECT_URL is below if overridden).
#
# GOOGLE_AUTH_CLIENT_ID=
# GOOGLE_AUTH_CLIENT_SECRET=
# GOOGLE_AUTH_REDIRECT_URL=  # default: <base URL>/auth/google/callback
# GOOGLE_AUTH_ALLOWED_DOMAINS=positron.ai  # comma-separated; default positron.ai
# GOOGLE_AUTH_ALLOWED_EMAILS=              # comma-separated, optional
# GOOGLE_AUTH_ALLOWED_SUBJECTS=            # comma-separated Google sub claims
