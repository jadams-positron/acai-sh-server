# infra/.env.example — production template for the Acai Go rewrite.
# Copy to infra/.env (gitignored) and fill in real values before deploying.
#
# Generate SECRET_KEY_BASE with: openssl rand -hex 32

INSTANCE_NAME=acai-prod
IMAGE_TAG_VERSION=latest

# --- App ---
LOG_LEVEL=info
SECRET_KEY_BASE=GENERATE_WITH_openssl_rand_hex_32

# --- URL ---
URL_HOST=app.acai.sh
URL_SCHEME=https
URL_PORT=443

# --- Caddy ---
CADDYFILE=prod
HTTP_PORT_EXT=80
HTTPS_PORT=443

# --- Mail ---
MAIL_NOOP=false
MAIL_FROM_NAME=acai.sh
MAIL_FROM_EMAIL=noreply@mg.acai.sh
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.acai.sh
MAILGUN_BASE_URL=https://api.mailgun.net/v3

# --- Litestream backup (S3 / Hetzner Object Storage compatible) ---
# Leave LITESTREAM_S3_BUCKET empty to disable replication (not recommended in prod).
LITESTREAM_S3_BUCKET=acai-prod
LITESTREAM_S3_REGION=nbg1
LITESTREAM_S3_ENDPOINT=https://nbg1.your-objectstorage.com
LITESTREAM_S3_PATH=acai.db
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
