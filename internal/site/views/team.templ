package views

import (
	"fmt"
	"strconv"

	"github.com/jadams-positron/acai-sh-server/internal/domain/products"
	"github.com/jadams-positron/acai-sh-server/internal/domain/teams"
	"github.com/jadams-positron/acai-sh-server/internal/services"
)

// TeamShowProps drives the /t/{team_name} page.
type TeamShowProps struct {
	Shell                ShellProps
	Team                 *teams.Team
	Products             []*products.Product
	Heatmap              *services.TeamHeatmap // nil when there are no products
	Members              []*teams.Member
	CSRFToken            string
	Flash                string
	PrefilledProductName string
}

templ TeamShow(p TeamShowProps) {
	@Shell(p.Shell) {
		<header class="page-header">
			<h1 class="title">{ p.Team.Name }</h1>
		</header>
		if p.Flash != "" {
			<div class="banner banner-error">{ p.Flash }</div>
		}
		<div data-signals="{showProductModal: false}" style="display: grid; gap: var(--space-xl);">
			if p.Heatmap != nil && p.Heatmap.AggregateTotal > 0 {
				@teamOverviewBanner(p.Heatmap)
				@teamHeatmap(p.Team.Name, p.Heatmap)
			}
			<section>
				<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-md);">
					<h2 style="font-size: var(--text-2xl); margin: 0;">Products</h2>
					<button class="button button-primary" data-on-click="$showProductModal = true" type="button">
						+ Create Product
					</button>
				</div>
				if len(p.Products) == 0 {
					<div class="empty-state empty-state-rich">
						<p class="empty-state-headline">No products yet</p>
						<p>A <strong>product</strong> is a container for the features you want to track. You'll group your specs, branches, and implementations under one. Create your first product to begin.</p>
						<div>
							<button class="button button-primary" data-on-click="$showProductModal = true" type="button">
								+ Create Product
							</button>
						</div>
					</div>
				} else {
					<div style="display: grid; gap: var(--space-md); grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));">
						for _, prod := range p.Products {
							<a
								href={ templ.SafeURL("/t/" + p.Team.Name + "/p/" + prod.Name) }
								class="panel"
								style="display: block; text-decoration: none; color: inherit;"
							>
								<h3 style="margin: 0 0 var(--space-xs); font-size: var(--text-lg);">{ prod.Name }</h3>
								if prod.Description != nil && *prod.Description != "" {
									<p class="subtitle" style="margin: 0;">{ *prod.Description }</p>
								} else {
									<p class="subtitle" style="margin: 0;">View product →</p>
								}
							</a>
						}
					</div>
				}
			</section>
			<section>
				<h2 style="font-size: var(--text-2xl); margin: 0 0 var(--space-md);">Members</h2>
				<div class="panel" style="padding: 0;">
					<table style="width: 100%; border-collapse: collapse;">
						<thead>
							<tr style="border-bottom: 1px solid var(--border-subtle);">
								<th style="text-align: left; padding: var(--space-md);">Email</th>
								<th style="text-align: left; padding: var(--space-md);">Role</th>
							</tr>
						</thead>
						<tbody>
							for _, m := range p.Members {
								<tr style="border-bottom: 1px solid var(--border-subtle);">
									<td style="padding: var(--space-md);">{ m.Email }</td>
									<td style="padding: var(--space-md);">
										<span class="badge">{ m.Role }</span>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</section>
			<div
				data-show="$showProductModal"
				style="position: fixed; inset: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 100;"
			>
				<div class="panel" style="max-width: 420px; width: 90%;" data-on-click__stop>
					<div class="panel-header">
						<h1>Create Product</h1>
					</div>
					<form method="post" action={ templ.SafeURL("/t/" + p.Team.Name + "/products") } class="form">
						<input type="hidden" name="gorilla.csrf.Token" value={ p.CSRFToken }/>
						<div class="form-field">
							<label class="form-label" for="product-name">Product name</label>
							<input
								id="product-name"
								class="form-input"
								type="text"
								name="name"
								value={ p.PrefilledProductName }
								required
								autofocus
								placeholder="my-product"
								pattern="[a-zA-Z0-9_.-]+"
								title="Alphanumeric, hyphens, underscores, and periods only"
							/>
						</div>
						<div style="display: flex; gap: var(--space-sm); justify-content: flex-end;">
							<button type="button" class="button button-ghost" data-on-click="$showProductModal = false">
								Cancel
							</button>
							<button type="submit" class="button button-primary">
								Create
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	}
}

templ teamOverviewBanner(h *services.TeamHeatmap) {
	<section class="panel" style="padding: var(--space-md) var(--space-lg);">
		<div style="display: flex; justify-content: space-between; align-items: center; gap: var(--space-md); flex-wrap: wrap;">
			<div>
				<p class="subtitle" style="margin: 0; font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.18em;">Progress</p>
				<p class="subtitle" style="margin: 2px 0 0;">
					{ pluralize(len(h.Rows), "product") }
					{ " · " }
					{ pluralize(h.ImplCount, "implementation") }
					{ " · " }
					{ pluralize(len(h.FeatureNames), "feature") }
					{ " · " }
					{ fmt.Sprintf("%d acceptance criteria", h.AggregateTotal) }
				</p>
			</div>
			<div style="display: flex; align-items: baseline; gap: var(--space-xs);">
				<span style="font-size: var(--text-xl); font-weight: 600; font-family: var(--font-mono);">
					{ fmt.Sprintf("%d%%", percentInt(h.AggregateCounts.Completed+h.AggregateCounts.Accepted, h.AggregateTotal)) }
				</span>
				<span class="subtitle" style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.12em;">complete</span>
			</div>
		</div>
		<div class="progress-quiet" style="margin-top: var(--space-md);">
			@progressBar(h.AggregateCounts, h.AggregateTotal)
		</div>
		<div style="margin-top: var(--space-sm);">
			@statusLegend(h.AggregateCounts)
		</div>
	</section>
}

// teamHeatmap renders the products × features matrix. Rows are products
// that have at least one feature with specs (others fold into a footer);
// columns are features (rotated -45° headers anchored to column-left); cells
// are colored by completion ratio with a red ring overlay when blocked.
templ teamHeatmap(teamName string, h *services.TeamHeatmap) {
	<section>
		<h2 style="font-size: var(--text-2xl); margin: 0 0 var(--space-md);">Coverage</h2>
		<p class="subtitle" style="margin: 0 0 var(--space-md); max-width: 64ch;">
			Each cell is one product's progress on one feature, summed across that product's implementations. Click a feature to see it across the team; click a product to drill in.
		</p>
		<div class="panel heatmap-panel">
			<div class="heatmap-scroll">
				<table class="heatmap" cellspacing="0" cellpadding="0">
					<thead>
						<tr>
							<th class="heatmap-corner"></th>
							for _, name := range h.FeatureNames {
								<th class="heatmap-th-feature" scope="col">
									<a href={ templ.SafeURL("/t/" + teamName + "/f/" + name) }>{ name }</a>
								</th>
							}
							<th class="heatmap-corner"></th>
						</tr>
					</thead>
					<tbody>
						for _, row := range h.Rows {
							if row.ProductPresent {
								@teamHeatmapRow(teamName, row)
							}
						}
					</tbody>
				</table>
			</div>
			if hiddenEmptyCount(h) > 0 {
				<p class="subtitle" style="margin: var(--space-sm) 0 0; font-size: var(--text-xs);">
					{ fmt.Sprintf("+ %s without specs yet — push from a tracked branch to add them to the matrix", pluralize(hiddenEmptyCount(h), "product")) }
				</p>
			}
			<div class="heatmap-legend">
				<span class="heatmap-legend-label">none</span>
				<span class="heatmap-legend-swatch" data-fill="0"></span>
				<span class="heatmap-legend-swatch" data-fill="25"></span>
				<span class="heatmap-legend-swatch" data-fill="50"></span>
				<span class="heatmap-legend-swatch" data-fill="75"></span>
				<span class="heatmap-legend-swatch" data-fill="100"></span>
				<span class="heatmap-legend-label">complete</span>
				<span style="width: var(--space-md);"></span>
				<span class="heatmap-legend-swatch heatmap-legend-blocked"></span>
				<span class="heatmap-legend-label">has blocked</span>
				<span style="width: var(--space-md);"></span>
				<span class="heatmap-legend-swatch heatmap-legend-empty"></span>
				<span class="heatmap-legend-label">not in product</span>
			</div>
		</div>
	</section>
}

templ teamHeatmapRow(teamName string, row *services.HeatmapRow) {
	<tr>
		<th class="heatmap-th-product" scope="row">
			<a href={ templ.SafeURL("/t/" + teamName + "/p/" + row.ProductName) }>{ row.ProductName }</a>
		</th>
		for _, cell := range row.Cells {
			@teamHeatmapCell(teamName, cell)
		}
		<td class="heatmap-cell-total">
			<div class="heatmap-cell-total-pct">
				{ fmt.Sprintf("%d%%", percentInt(row.ProductCounts.Completed+row.ProductCounts.Accepted, row.ProductTotal)) }
			</div>
			<div class="heatmap-cell-total-meta">
				{ fmt.Sprintf("%d ACIDs", row.ProductTotal) }
			</div>
		</td>
	</tr>
}

// hiddenEmptyCount returns the number of products in the matrix that
// have no specs yet — they're filtered out of the rendered grid but
// surfaced in a small footnote so the user knows they exist.
func hiddenEmptyCount(h *services.TeamHeatmap) int {
	n := 0
	for _, row := range h.Rows {
		if !row.ProductPresent {
			n++
		}
	}
	return n
}

templ teamHeatmapCell(teamName string, cell *services.HeatmapCell) {
	if !cell.Present {
		<td class="heatmap-cell heatmap-cell-empty" title={ cell.ProductName + " · " + cell.FeatureName + ": not in this product" }></td>
	} else {
		<td
			class={ heatmapCellClass(cell) }
			style={ "--cell-fill: " + heatmapCellFill(cell) }
			title={ heatmapCellTitle(cell) }
		>
			<a href={ templ.SafeURL("/t/" + teamName + "/f/" + cell.FeatureName) }></a>
		</td>
	}
}

// heatmapCellClass builds the cell's class list — the "blocked" modifier
// adds the red ring overlay; otherwise just the base present cell class.
func heatmapCellClass(c *services.HeatmapCell) string {
	if c.Counts.Blocked > 0 || c.Counts.Rejected > 0 {
		return "heatmap-cell heatmap-cell-present heatmap-cell-blocked"
	}
	return "heatmap-cell heatmap-cell-present"
}

// heatmapCellFill returns a 0-1 string used as the CSS variable for
// background opacity. Capped at 1.
func heatmapCellFill(c *services.HeatmapCell) string {
	if c.TotalRequirements <= 0 {
		return "0.05"
	}
	pct := float64(c.Counts.Completed+c.Counts.Accepted) / float64(c.TotalRequirements)
	if pct > 1 {
		pct = 1
	}
	// Floor of 0.08 so even 0% cells read as "present" vs. "empty".
	v := 0.08 + pct*0.55
	return strconv.FormatFloat(v, 'f', 2, 64)
}

// heatmapCellTitle composes the hover tooltip — keeps the data dense view
// glanceable without sacrificing exact counts on demand.
func heatmapCellTitle(c *services.HeatmapCell) string {
	done := c.Counts.Completed + c.Counts.Accepted
	blocked := c.Counts.Blocked + c.Counts.Rejected
	inflight := c.Counts.Assigned + c.Counts.Incomplete
	pct := 0
	if c.TotalRequirements > 0 {
		pct = (done * 100) / c.TotalRequirements
	}
	parts := fmt.Sprintf("%s · %s — %d/%d done (%d%%)",
		c.ProductName, c.FeatureName, done, c.TotalRequirements, pct)
	if blocked > 0 {
		parts += fmt.Sprintf(" · %d blocked", blocked)
	}
	if inflight > 0 {
		parts += fmt.Sprintf(" · %d in progress", inflight)
	}
	return parts
}
